# OpenAI ChatGPT API
OPENAI_API_KEY=your_openai_api_key_here

# 네이버 개발자센터 (데이터랩 API용)
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# 네이버 검색광고 (키워드도구 API용)
NAVER_AD_API_KEY=your_naver_ad_api_key_here
NAVER_AD_SECRET_KEY=your_naver_ad_secret_key_here
NAVER_AD_CUSTOMER_ID=your_naver_ad_customer_id_here

# 네이버 블로그 자동 포스팅 (선택, UI에서도 입력 가능)
NAVER_BLOG_ID=your_blog_id_here
